{% extends 'volunteers/base.html' %}

{% block title %}我的仪表盘 - 桑榆共暖{% endblock %}

{% block extra_css %}
<style>
    .dashboard-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 40px;
        border-radius: 15px;
        margin-bottom: 30px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    }
    
    .dashboard-header h1 {
        font-size: 32px;
        margin-bottom: 10px;
    }
    
    .dashboard-header p {
        opacity: 0.9;
        font-size: 18px;
    }
    
    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
        gap: 25px;
        margin-bottom: 40px;
    }
    
    .dashboard-card {
        background: white;
        border-radius: 12px;
        padding: 30px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.08);
        transition: transform 0.3s, box-shadow 0.3s;
    }
    
    .dashboard-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.12);
    }
    
    .card-header {
        display: flex;
        align-items: center;
        margin-bottom: 20px;
        padding-bottom: 15px;
        border-bottom: 2px solid #f0f0f0;
    }
    
    .card-icon {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-right: 15px;
        color: white;
        font-size: 20px;
    }
    
    .card-title {
        font-size: 20px;
        color: #333;
        font-weight: 600;
    }
    
    .status-badge {
        display: inline-block;
        padding: 8px 16px;
        border-radius: 50px;
        font-size: 14px;
        font-weight: 500;
        margin-bottom: 15px;
    }
    
    .status-pending {
        background: #fff3cd;
        color: #856404;
    }
    
    .status-approved {
        background: #d4edda;
        color: #155724;
    }
    
    .status-rejected {
        background: #f8d7da;
        color: #721c24;
    }
    
    .status-unverified {
        background: #e2e3e5;
        color: #383d41;
    }
    
    .user-info {
        margin: 20px 0;
    }
    
    .info-item {
        display: flex;
        margin-bottom: 12px;
        padding-bottom: 12px;
        border-bottom: 1px solid #f0f0f0;
    }
    
    .info-label {
        min-width: 100px;
        color: #666;
        font-weight: 500;
    }
    
    .info-value {
        flex: 1;
        color: #333;
    }
    
    .btn-group {
        display: flex;
        gap: 15px;
        margin-top: 20px;
        flex-wrap: wrap;
    }
    
    .btn {
        padding: 12px 25px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s;
        border: none;
        cursor: pointer;
    }
    
    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }
    
    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
    }
    
    .btn-secondary {
        background: #f1f5f9;
        color: #64748b;
        border: 1px solid #cbd5e1;
    }
    
    .btn-secondary:hover {
        background: #e2e8f0;
    }
    
    .btn-success {
        background: #10b981;
        color: white;
    }
    
    .btn-success:hover {
        background: #0da271;
        transform: translateY(-2px);
    }
    
    .quick-actions {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 15px;
        margin-top: 20px;
    }
    
    .quick-action {
        background: #f8fafc;
        border-radius: 8px;
        padding: 20px;
        text-align: center;
        border: 1px solid #e2e8f0;
        transition: all 0.3s;
        text-decoration: none;
        color: inherit;
        display: block;
    }
    
    .quick-action:hover {
        border-color: #667eea;
        background: white;
        transform: translateY(-3px);
    }
    
    .quick-action-icon {
        font-size: 24px;
        color: #667eea;
        margin-bottom: 10px;
    }
    
    .quick-action-title {
        font-weight: 600;
        color: #333;
        margin-bottom: 5px;
    }
    
    .quick-action-desc {
        font-size: 14px;
        color: #666;
    }
    
    .message-box {
        padding: 20px;
        border-radius: 10px;
        margin: 20px 0;
        border-left: 4px solid;
    }
    
    .message-info {
        background: #e7f3ff;
        border-color: #0066cc;
        color: #0066cc;
    }
    
    .message-success {
        background: #d4edda;
        border-color: #28a745;
        color: #155724;
    }
    
    .message-warning {
        background: #fff3cd;
        border-color: #ffc107;
        color: #856404;
    }
    
    @media (max-width: 768px) {
        .dashboard-header {
            padding: 25px;
        }
        
        .dashboard-grid {
            grid-template-columns: 1fr;
        }
        
        .btn-group {
            flex-direction: column;
        }
        
        .btn {
            width: 100%;
            justify-content: center;
        }
    }
</style>
{% endblock %}

{% block content %}
<div class="container">
    <div class="dashboard-header">
        <h1>欢迎回来，{{ user.username }}！</h1>
        <p>这里是您的个人中心，管理您的志愿服务信息</p>
    </div>
    
    <!-- 消息提示已移至 base.html -->
    
    <div class="dashboard-grid">
        <!-- 认证状态卡片 -->
        <div class="dashboard-card">
            <div class="card-header">
                <div class="card-icon">
                    <i class="fas fa-id-card"></i>
                </div>
                <div>
                    <h2 class="card-title">身份认证状态</h2>
                </div>
            </div>
            
            {% if user.profile %}
                <div class="status-badge 
                    {% if user.profile.verification_status == 'pending' %}status-pending
                    {% elif user.profile.verification_status == 'approved' %}status-approved
                    {% elif user.profile.verification_status == 'rejected' %}status-rejected
                    {% else %}status-unverified{% endif %}">
                    {% if user.profile.verification_status == 'pending' %}
                        <i class="fas fa-clock"></i> 审核中
                    {% elif user.profile.verification_status == 'approved' %}
                        <i class="fas fa-check-circle"></i> 已认证
                    {% elif user.profile.verification_status == 'rejected' %}
                        <i class="fas fa-times-circle"></i> 已拒绝
                    {% else %}
                        <i class="fas fa-exclamation-circle"></i> 未认证
                    {% endif %}
                </div>
                
                <div class="user-info">
                    <div class="info-item">
                        <span class="info-label">姓名：</span>
                        <span class="info-value">{{ user.profile.real_name|default:"未填写" }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">角色：</span>
                        <span class="info-value">{{ user.profile.get_role_display_name }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">手机号：</span>
                        <span class="info-value">{{ user.profile.phone_number|default:"未填写" }}</span>
                    </div>
                    {% if user.profile.verification_status != 'unverified' %}
                    <div class="info-item">
                        <span class="info-label">提交时间：</span>
                        <span class="info-value">
                            {% if user.profile.submitted_at %}
                                {{ user.profile.submitted_at|date:"Y年m月d日" }}
                            {% else %}
                                未提交
                            {% endif %}
                        </span>
                    </div>
                    {% endif %}
                </div>
                
                <div class="btn-group">
                    {% if user.profile.verification_status == 'unverified' %}
                        <a href="{% url 'role_selection' %}" class="btn btn-primary">
                            <i class="fas fa-user-check"></i> 开始认证
                        </a>
                    {% elif user.profile.verification_status == 'pending' %}
                        <a href="{% url 'verification_status' %}" class="btn btn-primary">
                            <i class="fas fa-search"></i> 查看审核状态
                        </a>
                    {% elif user.profile.verification_status == 'approved' %}
                        <a href="#" class="btn btn-success">
                            <i class="fas fa-check-circle"></i> 认证完成
                        </a>
                    {% elif user.profile.verification_status == 'rejected' %}
                        <a href="{% url 'profile_verification' %}" class="btn btn-primary">
                            <i class="fas fa-edit"></i> 修改认证信息
                        </a>
                    {% endif %}
                    
                    {% if user.profile.verification_status != 'unverified' %}
                        <a href="{% url 'verification_status' %}" class="btn btn-secondary">
                            <i class="fas fa-info-circle"></i> 查看详情
                        </a>
                    {% endif %}
                </div>
            {% else %}
                <div class="message-box message-warning">
                    <i class="fas fa-exclamation-triangle"></i> 您尚未完善个人信息
                </div>
                <div class="btn-group">
                    <a href="{% url 'role_selection' %}" class="btn btn-primary">
                        <i class="fas fa-user-plus"></i> 立即认证
                    </a>
                </div>
            {% endif %}
        </div>
        
        <!-- 快速操作卡片 -->
        <div class="dashboard-card">
            <div class="card-header">
                <div class="card-icon">
                    <i class="fas fa-bolt"></i>
                </div>
                <div>
                    <h2 class="card-title">快速操作</h2>
                </div>
            </div>
            
            <div class="quick-actions">
                {% if user.profile.verification_status == 'approved' %}
                    {% if user.profile.role == 'volunteer' %}
                        <a href="{% url 'activity_list' %}" class="quick-action">
                            <div class="quick-action-icon">
                                <i class="fas fa-search"></i>
                            </div>
                            <div class="quick-action-title">浏览活动</div>
                            <div class="quick-action-desc">寻找志愿服务机会</div>
                        </a>
                        
                        <a href="#" class="quick-action">
                            <div class="quick-action-icon">
                                <i class="fas fa-history"></i>
                            </div>
                            <div class="quick-action-title">我的报名</div>
                            <div class="quick-action-desc">查看报名记录</div>
                        </a>
                    {% elif user.profile.role == 'organizer' %}
                        <a href="{% url 'create_activity' %}" class="quick-action">
                            <div class="quick-action-icon">
                                <i class="fas fa-plus"></i>
                            </div>
                            <div class="quick-action-title">发布活动</div>
                            <div class="quick-action-desc">创建新的志愿服务活动</div>
                        </a>
                        
                        <a href="{% url 'organizer_activities' %}" class="quick-action">
                            <div class="quick-action-icon">
                                <i class="fas fa-tasks"></i>
                            </div>
                            <div class="quick-action-title">活动管理</div>
                            <div class="quick-action-desc">管理已发布的活动</div>
                        </a>
                    {% endif %}
                {% else %}
                    <div class="quick-action" style="cursor: default; opacity: 0.6;">
                        <div class="quick-action-icon">
                            <i class="fas fa-lock"></i>
                        </div>
                        <div class="quick-action-title">功能已锁定</div>
                        <div class="quick-action-desc">完成认证后解锁</div>
                    </div>
                {% endif %}
                
                <a href="{% url 'logout' %}" class="quick-action">
                    <div class="quick-action-icon">
                        <i class="fas fa-sign-out-alt"></i>
                    </div>
                    <div class="quick-action-title">安全退出</div>
                    <div class="quick-action-desc">结束当前会话</div>
                </a>
            </div>
        </div>
        
        <!-- 系统通知卡片 -->
        <div class="dashboard-card">
            <div class="card-header">
                <div class="card-icon">
                    <i class="fas fa-bell"></i>
                </div>
                <div>
                    <h2 class="card-title">系统通知</h2>
                </div>
            </div>
            
            <div class="notifications">
                {% if not user.profile %}
                    <div class="message-box message-warning">
                        <i class="fas fa-exclamation-circle"></i>
                        您还未完善个人资料，请尽快完成认证以解锁全部功能。
                    </div>
                {% elif user.profile.verification_status == 'unverified' %}
                    <div class="message-box message-warning">
                        <i class="fas fa-exclamation-circle"></i>
                        您还未进行身份认证，请尽快完成认证以解锁全部功能。
                    </div>
                {% elif user.profile.verification_status == 'pending' %}
                    <div class="message-box message-info">
                        <i class="fas fa-clock"></i>
                        您的认证申请正在审核中，通常需要1-3个工作日。
                    </div>
                {% elif user.profile.verification_status == 'approved' %}
                    <div class="message-box message-success">
                        <i class="fas fa-check-circle"></i>
                        恭喜！您已通过认证，可以参与志愿服务活动了。
                    </div>
                {% elif user.profile.verification_status == 'rejected' %}
                    <div class="message-box message-warning">
                        <i class="fas fa-exclamation-triangle"></i>
                        您的认证申请被拒绝，请根据审核意见修改后重新提交。
                    </div>
                {% endif %}
                
                <div class="message-box message-info">
                    <i class="fas fa-info-circle"></i>
                    如有任何问题，请联系平台管理员获取帮助。
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
